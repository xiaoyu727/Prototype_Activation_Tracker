{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@tokens": ["./tokens/index.ts"],
      "@doordash/prism-react": ["./src/lib/prism-react/index.tsx"]
    }
  },
  "include": ["tokens/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
